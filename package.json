{
  "name": "gem-router",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Gemini routing backend with API-key and CLI fallback.",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "pnpm exec turbo run build:app",
    "build:app": "tsc -p tsconfig.json",
    "check": "pnpm exec turbo run check:app",
    "check:app": "tsc --noEmit -p tsconfig.json",
    "dev": "pnpm run dev:app",
    "dev:app": "tsx watch src/index.ts",
    "setup:systemd": "bash ./ops/systemd/install-gemrouter-services.sh",
    "start": "pnpm run start:app",
    "start:app": "node dist/index.js",
    "smoke": "pnpm build && bash ./scripts/smoke.sh",
    "smoke:gemini-api": "pnpm build && SMOKE_BACKEND=gemini-api bash ./scripts/smoke.sh"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "turbo": "^2.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
