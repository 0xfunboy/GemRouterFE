# =============================================================================
# GemRouterFE local deployment
# =============================================================================

# Server bind address and public service port.
HOST=0.0.0.0
PORT=4024

# Repository and writable runtime data paths.
GEMROUTER_ROOT_DIR=/absolute/path/to/GemRouterFE
GEMROUTER_DATA_DIR=data

# Public URLs used by the dashboard and social metadata.
GEMROUTER_PUBLIC_BASE_URL=
GEMROUTER_VNC_PUBLIC_URL=

# =============================================================================
# Dashboard and compatibility surfaces
# =============================================================================

# Enable the operator dashboard.
GEMROUTER_DASHBOARD_ENABLED=true
GEMROUTER_ADMIN_SESSION_TTL_MS=86400000

# Dashboard users in username:password format.
GEMROUTER_DASHBOARD_ADMIN_USERS=admin:replace-me

# Default compatibility surface shown to clients.
GEMROUTER_COMPAT_DEFAULT_SURFACE=openai
GEMROUTER_COMPAT_ENABLED_SURFACES=openai,deepseek,ollama

# =============================================================================
# Local router auth and client policy
# =============================================================================

# Admin bearer token for privileged API calls.
GEMROUTER_ADMIN_TOKEN=replace-me

# Bootstrap app key used by local clients.
GEMROUTER_BOOTSTRAP_API_KEY=replace-me
GEMROUTER_BOOTSTRAP_APP_NAME=local-frontend
GEMROUTER_BOOTSTRAP_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://[::1]:*
GEMROUTER_BOOTSTRAP_ALLOWED_MODELS=gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-web,google/gemini-web
GEMROUTER_BOOTSTRAP_SESSION_NAMESPACE=local-frontend
GEMROUTER_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=30
GEMROUTER_BOOTSTRAP_MAX_CONCURRENCY=2

# =============================================================================
# Backend routing
# =============================================================================

# Normal flow: official Gemini API first, Gemini Web fallback, CLI diagnostic last.
GEMROUTER_BACKEND_ORDER=gemini-api,playwright,gemini-cli
GEMROUTER_ALLOW_PLAYWRIGHT_FALLBACK=true
GEMROUTER_BACKEND_RETRY_ON_CLI_AUTH_FAILURE=true

# =============================================================================
# Official Gemini API backend
# =============================================================================

# AI Studio / Gemini Developer API key path. Do not commit real keys.
GEMROUTER_GEMINI_API_ENABLED=false
GEMROUTER_GEMINI_API_KEYS=
GEMROUTER_GEMINI_API_KEYS_JSON=

# Gemini API endpoint and discovery version.
GEMROUTER_GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMROUTER_GEMINI_API_VERSION=v1beta

# Quota model. per-key assumes every key has an independent Google project/account.
GEMROUTER_GEMINI_API_DEFAULT_TIER=tier1
GEMROUTER_GEMINI_API_DEFAULT_QUOTA_GROUP_MODE=per-key
GEMROUTER_GEMINI_API_LIMITS_JSON=
GEMROUTER_GEMINI_API_LIMITS_PATH=

# Local quota ledger and model discovery cache.
GEMROUTER_GEMINI_API_LEDGER_PATH=data/gemini-api-quota-ledger.json
GEMROUTER_GEMINI_API_DISCOVERY_CACHE_PATH=data/gemini-api-models-cache.json
GEMROUTER_GEMINI_API_DISCOVERY_REFRESH_MS=3600000

# RPM/TPM/RPD windows and cooldown behavior.
GEMROUTER_GEMINI_API_QUOTA_COOLDOWN_MS=600000
GEMROUTER_GEMINI_API_RPD_WINDOW_MS=86400000
GEMROUTER_GEMINI_API_RPM_WINDOW_MS=60000
GEMROUTER_GEMINI_API_TPM_WINDOW_MS=60000
GEMROUTER_GEMINI_API_COUNT_TOKENS_PREFLIGHT=false
GEMROUTER_GEMINI_API_COUNT_FAILED_429_AS_USAGE=true

# Network timeouts.
GEMROUTER_GEMINI_API_TIMEOUT_MS=120000
GEMROUTER_GEMINI_API_STREAM_TIMEOUT_MS=180000

# =============================================================================
# Playwright / Gemini Web backend
# =============================================================================

# Gemini Web entrypoint and prompt formatting.
TEGEM_BASE_URL=https://gemini.google.com/app
TEGEM_PROMPT_PACKING_STYLE=minimal

# Headed browser runtime. VNC/noVNC attach to this display.
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_EXECUTABLE_PATH=/home/your-user/.local/bin/google-chrome-stable
PLAYWRIGHT_BASE_PROFILE_DIR=/absolute/path/to/GemRouterFE/.playwright/profiles
PLAYWRIGHT_PROFILE_NAMESPACE=chrome-stable
PLAYWRIGHT_VIEWPORT_WIDTH=1440
PLAYWRIGHT_VIEWPORT_HEIGHT=960
PLAYWRIGHT_DISPLAY=:99
PLAYWRIGHT_XVFB_SCREEN=1440x960x24
PLAYWRIGHT_VNC_PORT=5900
PLAYWRIGHT_NOVNC_PORT=6080
PLAYWRIGHT_NOVNC_WEB_ROOT=
PLAYWRIGHT_VNC_PASSWORD_FILE=/home/your-user/.vnc/passwd
TEGEM_IMPORT_PROFILE_FROM=

# Browser session lifecycle.
SESSION_IDLE_TIMEOUT_MS=1800000
SESSION_CONVERSATION_TTL_MS=86400000
MAX_SESSION_TABS=20
RESPONDED_SESSION_TTL_MS=90000
ORPHAN_SESSION_TTL_MS=600000
STREAM_POLL_INTERVAL_MS=700
STREAM_STABLE_TICKS=4
STREAM_FIRST_CHUNK_TIMEOUT_MS=25000
STREAM_MAX_DURATION_MS=90000

# =============================================================================
# Gemini CLI diagnostic backend
# =============================================================================

# Optional Code Assist path. Kept for diagnostics and forced backend tests.
GEMINI_CLI_ENABLED=true
GEMINI_CLI_MODEL=gemini-2.5-pro
GEMINI_CLI_MODELS=gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_CLI_TIMEOUT_MS=120000
GEMINI_CLI_QUOTA_REFRESH_MS=60000

# Cached auth visibility and bootstrap mode.
GEMINI_CLI_EXPECT_AUTH_CACHE=true
GEMINI_CLI_AUTH_BOOTSTRAP_ENABLED=true
GEMINI_CLI_AUTH_BOOTSTRAP_MODE=operator
GEMINI_CLI_USER_HOME=
GEMINI_CLI_DOT_GEMINI_DIR=

# OAuth client used only by the Gemini CLI login helper.
GEMINI_AUTH_CALLBACK_HOST=127.0.0.1
GEMINI_AUTH_CALLBACK_PORT=
GEMINI_AUTH_AUTO_OPEN_BROWSER=true
GEMINI_AUTH_CLIENT_ID=
GEMINI_AUTH_CLIENT_SECRET=
