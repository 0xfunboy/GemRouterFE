# =============================================================================
# LeakRouter local deployment
# =============================================================================

HOST=0.0.0.0
PORT=4024

LEAKROUTER_ROOT_DIR=/home/funboy/leakrouter
LEAKROUTER_DATA_DIR=data
LEAKROUTER_PUBLIC_BASE_URL=http://127.0.0.1:4024

# =============================================================================
# Admin UI and client auth
# =============================================================================

LEAKROUTER_DASHBOARD_ENABLED=true
LEAKROUTER_ADMIN_TOKEN=replace-admin-token
LEAKROUTER_ADMIN_SESSION_TTL_MS=86400000
LEAKROUTER_DASHBOARD_ADMIN_USERS=admin:replace-admin-password

LEAKROUTER_BOOTSTRAP_API_KEY=replace-client-token
LEAKROUTER_BOOTSTRAP_APP_NAME=local-client
LEAKROUTER_BOOTSTRAP_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://[::1]:*
LEAKROUTER_BOOTSTRAP_SESSION_NAMESPACE=local-client
LEAKROUTER_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=30
LEAKROUTER_BOOTSTRAP_MAX_CONCURRENCY=2
LEAKROUTER_BOOTSTRAP_CONCURRENCY_WAIT_MS=90000

# Optional. Leave empty to allow every model discovered in the Ollama inventory
# plus LEAKROUTER_DEEPSEEK_MODELS.
LEAKROUTER_BOOTSTRAP_ALLOWED_MODELS=

# =============================================================================
# Routing modes
# =============================================================================

# Available backend modes: ollama, deepseek-api.
LEAKROUTER_BACKEND_ORDER=ollama,deepseek-api

# Public compatibility surfaces.
LEAKROUTER_COMPAT_DEFAULT_SURFACE=ollama
LEAKROUTER_COMPAT_ENABLED_SURFACES=openai,deepseek,ollama

# =============================================================================
# Ollama mode
# =============================================================================

LEAKROUTER_OLLAMA_ENABLED=true
LEAKROUTER_OLLAMA_INVENTORY_PATH=ollama-model-inventory.json
LEAKROUTER_OLLAMA_TIMEOUT_MS=120000
LEAKROUTER_OLLAMA_STREAM_TIMEOUT_MS=180000

# Optional explicit public model list/default. When empty, the inventory drives it.
LEAKROUTER_MODELS=
LEAKROUTER_DEFAULT_MODEL=
LEAKROUTER_TEXT_MODELS=
LEAKROUTER_FALLBACK_MODELS=

# =============================================================================
# DeepSeek API mode
# =============================================================================

LEAKROUTER_DEEPSEEK_ENABLED=false
LEAKROUTER_DEEPSEEK_API_KEY=
LEAKROUTER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LEAKROUTER_DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner
LEAKROUTER_DEEPSEEK_DEFAULT_MODEL=deepseek-chat
LEAKROUTER_DEEPSEEK_TIMEOUT_MS=120000

# =============================================================================
# Generation defaults
# =============================================================================

LEAKROUTER_INCLUDE_THOUGHTS=false
LEAKROUTER_STRIP_REASONING=true
LEAKROUTER_THINKING_LEVEL=minimal
LEAKROUTER_THINKING_BUDGET=0
